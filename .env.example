DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=qoda_db
DB_USER=root
DB_PASS=

# Required in production. Use long random values and configure them in Railway variables.
JWT_SECRET=
QODA_APP_SECRET=
QODA_SOCKET_SECRET=

# Optional ChatGPT-assisted code grading.
# Add OPENAI_API_KEY in Railway variables to enable the ChatGPT rubric grader.
QODA_AI_GRADING_ENABLED=auto
QODA_AI_GRADING_MODEL=gpt-4.1-mini
QODA_AI_GRADING_TIMEOUT=45
OPENAI_API_KEY=

# Optional production flags.
QODA_DEBUG=0
